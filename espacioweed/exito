      0% { transform: scale(1); opacity: 1; }
      50% { transform: scale(1.1); opacity: 0.8; }
      100% { transform: scale(1); opacity: 1; }
    }
  </style>
</head>
<body>
  <div class="success-card">
    <i class="fas fa-check-circle icon-check"></i>
    <h1>¡PAGO CONFIRMADO!</h1>
    <p>La transacción fue un éxito. El combustible está listo para el despegue.</p>
    
    <a href="#" id="link-wa" class="btn-exito btn-wa">
      <i class="fab fa-whatsapp" style="font-size: 1.2rem;"></i> COORDINAR ENTREGA
    </a>
    
    <a href="<?= ScriptApp.getService().getUrl() ?>" class="btn-exito btn-nave">
      <i class="fas fa-rocket"></i> VOLVER A LA NAVE
    </a>
  </div>

  <script>
    // 1. Extraemos los IDs que Mercado Pago envía ocultos en la URL
    const params = new URLSearchParams(window.location.search);
    const numMP = params.get('payment_id') || 'En proceso';
    const numPedido = params.get('external_reference') || 'Pendiente';

    // 2. Rescatamos el listado de productos de la memoria temporal del navegador
    let listaProductos = "Ver detalle en sistema";
    try {
      // El carrito suele guardarse como 'carrito' o 'carritoWeed' en la memoria
      let memoriaCarrito = localStorage.getItem('carrito') || localStorage.getItem('carritoWeed');
      if (memoriaCarrito) {
        let items = JSON.parse(memoriaCarrito);
        // Armamos la lista con este formato: "2x Aceite, 1x Crema"
        listaProductos = items.map(i => i.cantidad + "x " + (i.nombre || i.producto)).join("%0A- ");
        
        // 3. BONUS: Vaciamos el carrito del cliente porque la compra ya fue un éxito
        localStorage.removeItem('carrito');
        localStorage.removeItem('carritoWeed');
        // Actualizamos el contador visual si existe
        if(document.getElementById('cart-count')) document.getElementById('cart-count').innerText = "0";
      }
    } catch(e) {
      console.log("No se pudo extraer el detalle del carrito.");
    }

    // 4. Conectamos con el servidor para sacar el número de WhatsApp
    google.script.run.withSuccessHandler(function(config) {
      const wa = config['WHATSAPP'] || config['WHATSAPP_ADMIN'];
      if(wa) {
        const numLimpio = wa.toString().replace(/\D/g, ''); 
        
        // 5. Armamos el Súper Mensaje de Neuroventas (usando %0A para los saltos de línea)
        let mensaje = "¡Hola Espacio Weed! Acabo de completar un pago en la web. Escribo para coordinar la entrega. 🚀%0A%0A";
        mensaje += "📦 *N° de Pedido:* " + numPedido + "%0A";
        mensaje += "💳 *Comprobante MP:* " + numMP + "%0A";
        mensaje += "🛍️ *Mis Productos:*%0A- " + listaProductos;
        
        document.getElementById('link-wa').href = "https://wa.me/" + numLimpio + "?text=" + mensaje;
      }
    }).getConfig();
  </script>
</body>
