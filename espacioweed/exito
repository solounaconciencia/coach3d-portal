    .icon-check { font-size: 4rem; color: var(--neon-green); margin-bottom: 20px; animation: pulse 2s infinite; }
    h1 { font-family: 'Orbitron'; font-size: 1.5rem; margin-bottom: 10px; color: var(--neon-green); }
