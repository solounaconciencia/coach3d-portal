    .btn-exito {
      display: flex; justify-content: center; align-items: center; gap: 10px;
      width: 100%; padding: 15px; margin-bottom: 15px; border-radius: 10px;
      text-decoration: none; font-weight: bold; font-family: 'Orbitron'; font-size: 0.9rem;
      transition: 0.3s; border: none; cursor: pointer; box-sizing: border-box;
    }
    .btn-wa { background: var(--neon-green); color: black; }
    .btn-wa:hover { background: white; transform: scale(1.02); }
    
